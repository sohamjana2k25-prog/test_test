# ContentForge — Frontend Environment Variables
# Copy this to .env and fill in values from SAM deployment outputs

# ─── AWS Credentials ─────────────────────────────────────────────
# Option 1: IAM User credentials (for development/demo)
VITE_AWS_REGION=ap-south-1
VITE_AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
VITE_AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
VITE_AWS_SESSION_TOKEN=   # Leave empty if not using STS temporary credentials

# ─── API Gateway ─────────────────────────────────────────────────
# From SAM deployment output: ApiGatewayUrl
VITE_API_GATEWAY_URL=https://xxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod

# ─── S3 ──────────────────────────────────────────────────────────
# From SAM deployment output: S3BucketName
VITE_S3_BUCKET=contentforge-prod-123456789012

# ─── Cognito ─────────────────────────────────────────────────────
# From SAM deployment output: CognitoUserPoolId and CognitoClientId
VITE_COGNITO_USER_POOL_ID=ap-south-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
